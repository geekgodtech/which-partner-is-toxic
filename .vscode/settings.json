{
    "files.autoSave": "afterDelay",
    "editor.defaultFormatter": "vscode.json-language-features",
    "editor.wordWrap": "on",

    // ── Spell Checker (Code Spell Checker extension) ──────────────────────────
    "cSpell.enabled": true,
    "cSpell.language": "en",

    // Words specific to this project that are not real English words
    "cSpell.words": [
        "AIRTA",
        "airta",
        "toxicity",
        "deepseek",
        "DeepSeek",
        "unipile",
        "Unipile",
        "gaslighting",
        "stonewalling",
        "hoovering",
        "DARVO",
        "keystore",
        "buildTypes",
        "minSdk",
        "targetSdk",
        "compileSdk",
        "ndkVersion",
        "signingConfig",
        "signingConfigs",
        "proguard",
        "Proguard",
        "assembleRelease",
        "appbundle",
        "pubspec",
        "ChangeNotifier",
        "notifyListeners",
        "SharedPreferences",
        "TextEditingController",
        "BuildContext",
        "StatefulWidget",
        "StatelessWidget",
        "initState",
        "FittedBox",
        "InkWell",
        "ColorScheme",
        "SizedBox",
        "EdgeInsets",
        "BorderRadius",
        "LinearGradient",
        "AnimatedScale",
        "GridView",
        "SliverGrid",
        "SingleChildScrollView",
        "ConstrainedBox",
        "Padding",
        "AlertDialog",
        "SnackBar",
        "arb",
        "l10n",
        "localizations",
        "Localizations",
        "prefs",
        "onPressed",
        "onTap",
        "appbar",
        "AppBar",
        "Scaffold",
        "Kennyloggins",
        "geekgodtech",
        "RFCX",
        "sideloaded",
        "sideload",
        "IAP",
        "consumable",
        "playstore",
        "gms",
        "multidex",
        "androidx",
        "firebase",
        "Firebase",
        "Firestore",
        "crashlytics"
    ],

    // Don't spell-check generated or binary files
    "cSpell.ignorePaths": [
        "**/node_modules/**",
        "**/.git/**",
        "**/build/**",
        "**/*.g.dart",
        "**/app_localizations*.dart",
        "**/l10n/**",
        "**/Screenshots/**",
        "**/*.arb",
        "**/pubspec.lock"
    ]
}
