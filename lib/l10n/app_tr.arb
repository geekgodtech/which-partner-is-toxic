  "metric_narcissist_32_name": "Terk Etme Tehditleri",
  "metric_narcissist_32_description": "Uyum veya ilgi sağlamak için kaybetme veya reddedilme korkusunu kullanmak.",
  "metric_narcissist_33_name": "Mağdur Rolü Oynama",
