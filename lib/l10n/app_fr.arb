  "metric_1_name": "Mépris",
  "metric_1_description": "Recherche la supériorité, le dégoût, la moquerie, le langage de roulage des yeux ou les insultes qui placent un partenaire en dessous de l'autre.",
  "metric_2_name": "Défensive",
  "metric_2_description": "Suit l'autoprotection réflexe, les contre-attaques, les excuses et le refus de considérer la plainte de l'autre personne.",
  "metric_3_name": "Blocage",
  "metric_3_description": "Identifie l'arrêt, le retrait, l'ignorance, le refus de répondre ou la fin des conversations pour éviter l'engagement.",
  "metric_4_name": "Critique",
  "metric_4_description": "Détecte les attaques sur le caractère ou la personnalité au lieu de comportements, besoins ou incidents spécifiques.",
  "metric_5_name": "Indicateurs de Gaslighting",
  "metric_5_description": "Signale les tentatives de faire douter quelqu'un de sa mémoire, perception, santé mentale ou légitimité de son expérience.",
  "metric_6_name": "Transfert de Blâme",
  "metric_6_description": "Mesure si la responsabilité est redirigée vers l'autre partenaire au lieu d'être reconnue directement.",
  "metric_7_name": "Motif d'Escalade",
  "metric_7_description": "Évalue si le ton, les accusations, l'intensité ou les menaces augmentent au lieu de se diriger vers une résolution.",
  "metric_8_name": "Reconnaissance des Tentatives de Réparation",
  "metric_8_description": "Vérifie si les excuses, l'humour, les pauses, la réassurance ou les offres de paix sont remarquées et acceptées.",
  "metric_9_name": "Langage de Responsabilité",
  "metric_9_description": "Recherche une propriété claire du préjudice, une responsabilité spécifique et la volonté de changer le comportement.",
  "metric_10_name": "Respect des Limites",
  "metric_10_description": "Évalue si les limites énoncées autour du temps, de la vie privée, du corps, des émotions ou du contact sont respectées.",
  "metric_11_name": "Indicateurs de Contrôle Coercitif",
  "metric_11_description": "Signale les modèles d'intimidation, de restriction, de surveillance, de dépendance ou de contrôle sur les choix et les mouvements.",
  "metric_12_name": "Langage de Menace",
  "metric_12_description": "Identifie les menaces explicites ou implicites impliquant la sécurité, l'abandon, l'exposition, la représaille ou la punition.",
  "metric_13_name": "Dédain",
  "metric_13_description": "Détecte le rejet des préoccupations, le traitement des besoins comme sans importance ou le refus de prendre la détresse au sérieux.",
  "metric_14_name": "Invalidation",
  "metric_14_description": "Mesure le déni, la moquerie ou la correction des émotions d'une autre personne au lieu de les reconnaître.",
  "metric_15_name": "Expression d'Empathie",
  "metric_15_description": "Recherche la prise de perspective, le soin, la reconnaissance émotionnelle et la préoccupation pour l'expérience de l'autre personne.",
  "metric_16_name": "Réciprocité",
  "metric_16_description": "Évalue si l'attention, l'effort, les excuses, le compromis et le soutien émotionnel circulent dans les deux sens.",
  "metric_17_name": "Régulation Émotionnelle",
  "metric_17_description": "Évalue la capacité de rester ancré, de faire une pause, de s'apaiser et de communiquer sans réactivité explosive.",
  "metric_18_name": "Sarcasme Utilisé comme Dommage",
  "metric_18_description": "Signale le sarcasme utilisé pour rabaisser, punir, humilier ou déguiser l'hostilité comme humour.",
  "metric_19_name": "Injures",
  "metric_19_description": "Identifie les étiquettes dérogatoires, les insultes, le blasphème dirigé contre la personne ou les attaques basées sur l'identité.",
  "metric_20_name": "Motif de Traitement Silencieux",
  "metric_20_description": "Suit le silence utilisé comme punition, contrôle, évitement ou retrait de connexion.",
  "metric_21_name": "Cadre de Jalousie",
  "metric_21_description": "Évalue la suspicion, la possessivité, les accusations ou la jalousie présentées comme preuve de soin.",
  "metric_22_name": "Pression d'Isolation",
  "metric_22_description": "Signale les efforts pour séparer un partenaire des amis, de la famille, des systèmes de soutien ou des perspectives extérieures.",
  "metric_23_name": "Indicateurs de Contrôle Financier",
  "metric_23_description": "Recherche le contrôle de l'argent, des dépenses, de l'emploi, de l'accès aux comptes ou de l'indépendance financière.",
  "metric_24_name": "Indicateurs d'Invasion de la Vie Privée",
  "metric_24_description": "Détecte l'espionnage, les demandes de mots de passe, les vérifications d'appareils, le suivi de localisation ou les violations de la vie privée.",
  "metric_25_name": "Spécificité des Excuses",
  "metric_25_description": "Mesure si les excuses nomment le préjudice exact, l'impact et la correction future au lieu de rester vagues.",
  "metric_26_name": "Pression de Pardon",
  "metric_26_description": "Signale les demandes de passer à autre chose, de pardonner rapidement ou d'arrêter de discuter du préjudice avant la réparation.",
  "metric_27_name": "Minimisation",
  "metric_27_description": "Détecte la minimisation du préjudice, l'appel des préoccupations sérieuses dramatiques ou la réduction de l'impact pour éviter la responsabilité.",
  "metric_28_name": "Projection",
  "metric_28_description": "Recherche les accusations qui reflètent le propre comportement, les motifs ou les sentiments non résolus du locuteur.",
  "metric_29_name": "Motif d'Interruption",
  "metric_29_description": "Suit les coupures, le fait de parler par-dessus, le refus de terminer ou le contrôle des tours de conversation.",
  "metric_30_name": "Déviation de Sujet",
  "metric_30_description": "Identifie le changement de sujet, l'introduction de problèmes non liés ou l'évitement de la préoccupation centrale.",
  "metric_31_name": "Orientation vers la Résolution",
  "metric_31_description": "Mesure si les messages visent des solutions, de la clarté, des accords et les prochaines étapes.",
  "metric_32_name": "Résolution Mutuelle de Problèmes",
  "metric_32_description": "Évalue le langage collaboratif, la responsabilité partagée, le brainstorming et la volonté de trouver des compromis viables.",
  "metric_33_name": "Inondation Émotionnelle",
  "metric_33_description": "Détecte le débordement, la panique, l'arrêt, la spirale ou l'incapacité de traiter pendant le conflit.",
  "metric_34_name": "Indices de Réponse de Peur",
  "metric_34_description": "Recherche l'apaisement, un choix de mots prudent, la crainte, les préoccupations de sécurité ou la peur de la réaction du partenaire.",
  "metric_35_name": "Cohérence des Affirmations",
  "metric_35_description": "Évalue si les récits restent cohérents en interne à travers les messages et le temps.",
  "metric_36_name": "Souvenir Basé sur des Preuves",
  "metric_36_description": "Vérifie si les affirmations font référence à des événements concrets, des citations, des chronologies ou un comportement observable.",
  "metric_37_name": "Motif de Demande et de Retrait",
  "metric_37_description": "Suit un partenaire cherchant des réponses ou un changement pendant que l'autre évite, se ferme ou sort.",
  "metric_38_name": "Indicateurs de Déséquilibre de Pouvoir",
  "metric_38_description": "Signale un pouvoir de décision inégal, la peur des conséquences, la dépendance, l'intimidation ou le contrôle unilatéral.",
  "metric_39_name": "Désaccord Respectueux",
  "metric_39_description": "Mesure si le conflit préserve la dignité, la curiosité et le désaccord sans dégradation.",
  "metric_40_name": "Cycle de Rupture et Réparation",
  "metric_40_description": "Évalue si le conflit est suivi d'une reconnaissance, d'une reconnexion et d'une réparation réelle.",
  "metric_41_name": "Retrait d'Affection",
  "metric_41_description": "Détecte l'amour, la chaleur, le sexe, l'attention ou la réassurance retenus comme punition ou levier.",
  "metric_42_name": "Références d'Humiliation Publique",
  "metric_42_description": "Signale les menaces, les blagues ou les actions qui embarrassent le partenaire devant les autres.",
  "metric_43_name": "Indices de Conflit Lié aux Substances",
  "metric_43_description": "Recherche l'utilisation d'alcool ou de drogues liée à l'agression, au manque de fiabilité, au conflit ou au préjudice.",
  "metric_44_name": "Pression de Conflit Parental",
  "metric_44_description": "Identifie les enfants, la garde, les rôles parentaux ou la culpabilité parentale utilisés dans le conflit ou comme levier.",
  "metric_45_name": "Respect des Limites Sexuelles",
  "metric_45_description": "Évalue le respect du consentement, de la pression, du refus, du confort, du timing et de l'autonomie sexuelle.",
  "metric_46_name": "Indicateurs de Harcèlement Numérique",
  "metric_46_description": "Suit les messages indésirables répétés, les appels spam, la pression en ligne, la surveillance ou l'intimidation basée sur les plateformes.",
  "metric_47_name": "Langage de Surveillance",
  "metric_47_description": "Signale la vérification des allées et venues, la demande de preuves, le suivi du comportement ou la vérification constante.",
  "metric_48_name": "Orientation Future",
  "metric_48_description": "Mesure si les partenaires discutent d'amélioration future, d'engagements, de plans ou d'une direction constructive.",
  "metric_49_name": "Signaux de Planification de Sécurité",
  "metric_49_description": "Recherche les tentatives de chercher de l'aide, de créer une distance, de documenter le préjudice ou de planifier la sécurité physique/émotionnelle.",
  "metric_50_name": "Tentatives Mutuelles de Désescalade",
  "metric_50_description": "Suit les pauses, le langage apaisant, un ton plus doux, les temps morts et les tentatives des deux partenaires pour réduire l'intensité.",
  "metric_51_name": "Indices d'Attachement Sécurisé",
  "metric_51_description": "Identifie la confiance, la réassurance directe, la disponibilité émotionnelle et le confort avec la proximité et l'indépendance.",
  "metric_52_name": "Activation de l'Attachement Anxieux",
  "metric_52_description": "Signale le comportement de protestation, les besoins urgents de réassurance, la peur de l'abandon et une sensibilité accrue à la distance.",
  "metric_53_name": "Distanciation de l'Attachement Évitant",
  "metric_53_description": "Détecte la minimisation émotionnelle, les défenses d'indépendance, le retrait de la vulnérabilité ou l'inconfort avec les besoins.",
  "metric_54_name": "Signaux d'Attachement Désorganisé",
  "metric_54_description": "Recherche les cycles d'approche-évitement, la peur mélangée au besoin, les réactions chaotiques ou les modèles d'intimité confus.",
  "metric_55_name": "Offres Émotionnelles et Réponses",
  "metric_55_description": "Mesure les invitations pour l'attention, le confort ou la connexion et si elles sont acceptées ou manquées.",
  "metric_56_name": "Se Détourner de la Connexion",
  "metric_56_description": "Signale l'ignorance, le rejet ou l'échec à répondre aux offres de proximité ou de soutien.",
  "metric_57_name": "Se Retourner Contre la Connexion",
  "metric_57_description": "Détecte les réponses hostiles ou punitives aux tentatives d'affection, de vulnérabilité ou de réparation.",
  "metric_58_name": "Primauté du Sentiment Positif",
  "metric_58_description": "Recherche la générosité, le bénéfice du doute, l'affection et l'interprétation du conflit à travers le soin.",
  "metric_59_name": "Primauté du Sentiment Négatif",
  "metric_59_description": "Signale l'hypothèse de mauvaises intentions, l'interprétation négative des messages neutres et le cadre hostile persistant.",
  "metric_60_name": "Motif de Départ Dur",
  "metric_60_description": "Identifie les conversations qui commencent par une accusation, une attaque, le mépris ou le blâme plutôt qu'une demande.",
  "metric_61_name": "Motif de Départ Doux",
  "metric_61_description": "Recherche des ouvertures douces utilisant des sentiments, des besoins, des demandes spécifiques et un langage non accusatoire.",
  "metric_62_name": "Auto-apaisement Physiologique",
  "metric_62_description": "Évalue les tentatives de faire une pause, de respirer, de prendre de l'espace ou de réguler le corps avant de continuer le conflit.",
  "metric_63_name": "Motif d'Évitement de Conflit",
  "metric_63_description": "Suit l'évitement répété de sujets nécessaires, de l'inconfort, du désaccord ou de l'honnêteté émotionnelle.",
  "metric_64_name": "Style de Conflit Volatile",
  "metric_64_description": "Détecte un conflit de haute intensité avec une expression directe qui peut encore inclure l'engagement et la réparation.",
  "metric_65_name": "Style de Conflit Validant",
  "metric_65_description": "Mesure si les partenaires reconnaissent la perspective de l'autre tout en étant en désaccord.",
  "metric_66_name": "Style de Conflit Hostile",
  "metric_66_description": "Signale la critique fréquente, le mépris, la défensive, les attaques et le cadre adversarial.",
  "metric_67_name": "Motif Hostile-Détaché",
  "metric_67_description": "Identifie l'hostilité froide, le désengagement émotionnel, le mépris et une faible motivation de réparation.",
  "metric_68_name": "Volonté de Compromis",
  "metric_68_description": "Recherche la flexibilité, la négociation, les propositions de terrain d'entente et les sacrifices qui respectent les deux besoins.",
  "metric_69_name": "Acceptation de l'Influence",
  "metric_69_description": "Mesure l'ouverture à être affecté par les sentiments, les besoins ou la perspective du partenaire.",
  "metric_70_name": "Signaux de Conflit Bloqué",
  "metric_70_description": "Signale des problèmes non résolus répétés liés aux valeurs, aux rêves, à l'identité ou à l'incompatibilité chronique.",
  "metric_71_name": "Cadre de Problème Soluble",
  "metric_71_description": "Détecte des définitions de problèmes pratiques et concrètes qui peuvent mener à des accords spécifiques.",
  "metric_72_name": "Références de Sens Partagé",
  "metric_72_description": "Recherche les valeurs, les rituels, les objectifs, les souvenirs ou le langage d'identité qui crée une histoire de relation partagée.",
  "metric_73_name": "Conscience de la Carte d'Amour",
  "metric_73_description": "Évalue la connaissance du monde intérieur, des facteurs de stress, des préférences, des peurs et de la vie quotidienne du partenaire.",
  "metric_74_name": "Affection et Admiration",
  "metric_74_description": "Identifie l'appréciation, le respect, la chaleur, les compliments, la gratitude et le regard positif.",
  "metric_75_name": "Déséquilibre du Travail Émotionnel",
  "metric_75_description": "Signale un partenaire portant une planification disproportionnée, l'apaisement, le souvenir, l'explication ou l'entretien de la relation.",
  "metric_76_name": "Rejet de la Charge Mentale",
  "metric_76_description": "Détecte la minimisation du travail de planification invisible, la coordination ménagère, la planification ou le suivi des responsabilités.",
  "metric_77_name": "Indices d'Incompétence Armée",
  "metric_77_description": "Recherche les revendications d'incapacité, de confusion ou d'impuissance pour éviter une responsabilité équitable.",
  "metric_78_name": "Sensibilité aux Déclencheurs de Trauma",
  "metric_78_description": "Mesure la conscience des déclencheurs, des réponses au trauma et la manipulation prudente des sujets vulnérables.",
  "metric_79_name": "Indices d'Hypervigilance",
  "metric_79_description": "Signale la recherche de danger, la surveillance excessive du ton, la peur des erreurs ou l'alerte émotionnelle constante.",
  "metric_80_name": "Langage de Peur de l'Abandon",
  "metric_80_description": "Détecte la peur d'être laissé, remplacé, ignoré, rejeté ou abandonné émotionnellement.",
  "metric_81_name": "Motif de Recherche de Réassurance",
  "metric_81_description": "Suit les demandes répétées de preuve d'amour, d'engagement, de sécurité ou d'intérêt continu.",
  "metric_82_name": "Cycle Poursuivant-Distant",
  "metric_82_description": "Identifie un partenaire qui intensifie la poursuite de proximité pendant que l'autre augmente la distance.",
  "metric_83_name": "Accumulation de Ressentiment",
  "metric_83_description": "Recherche les griefs stockés, les références répétées au passé, l'amertume et la dette émotionnelle non résolue.",
  "metric_84_name": "Comportement de Comptage de Points",
  "metric_84_description": "Signale le comptage transactionnel des fautes, des faveurs, des sacrifices ou des erreurs pour gagner un levier.",
  "metric_85_name": "Affection Conditionnelle",
  "metric_85_description": "Détecte l'amour, l'approbation, l'accès ou la chaleur offerts uniquement lorsque la conformité est atteinte.",
  "metric_86_name": "Indicateurs de Love Bombing",
  "metric_86_description": "Signale l'affection intense, les promesses, la pression ou l'idéalisation utilisées pour accélérer l'attachement ou le contrôle.",
  "metric_87_name": "Tentatives de Hoovering",
  "metric_87_description": "Identifie les tentatives de ramener quelqu'un par la culpabilité, la nostalgie, les promesses, les crises ou l'affection soudaine.",
  "metric_88_name": "Motif DARVO",
  "metric_88_description": "Détecte les réponses de nier, attaquer et inverser victime-auteur lorsqu'on est confronté à un préjudice.",
  "metric_89_name": "Motif de Posture de Victime",
  "metric_89_description": "Signale l'auto-victimisation récurrente qui évite la responsabilité ou redirige l'attention du préjudice causé.",
  "metric_90_name": "Cadre de Supériorité Morale",
  "metric_90_description": "Recherche la droiture, les revendications de pureté ou la supériorité éthique utilisées pour dominer le conflit.",
  "metric_91_name": "Assassinat de Caractère",
  "metric_91_description": "Détecte des attaques larges sur l'identité, l'intégrité, la santé mentale ou la valeur plutôt que sur un comportement spécifique.",
  "metric_92_name": "Indicateurs de Triangulation",
  "metric_92_description": "Signale l'introduction de tiers dans le conflit pour presser, comparer, valider ou déstabiliser le partenaire.",
  "metric_93_name": "Pression de Comparaison Sociale",
  "metric_93_description": "Recherche les comparaisons avec des ex, des amis, d'autres couples ou des idéaux utilisés pour honte ou contraindre.",
  "metric_94_name": "Soutien de l'Autonomie",
  "metric_94_description": "Mesure le respect des choix indépendants, des amitiés, des objectifs, des limites et de l'agence personnelle.",
  "metric_95_name": "Respect du Consentement et du Choix",
  "metric_95_description": "Évalue si les décisions sont prises librement sans pression, culpabilité, menaces ou manipulation.",
  "metric_96_name": "Planification Collaborative",
  "metric_96_description": "Recherche la planification partagée, les décisions conjointes, les responsabilités coordonnées et le suivi pratique.",
  "metric_97_name": "Suivi de Réparation",
  "metric_97_description": "Mesure si les changements promis sont ensuite reflétés dans le comportement, pas seulement dans les mots.",
  "metric_98_name": "Preuve de Comportement Changé",
  "metric_98_description": "Vérifie les actions observables et répétées montrant l'apprentissage, l'ajustement ou le comportement nocif réduit.",
  "metric_99_name": "Langage de Sécurité Émotionnelle",
  "metric_99_description": "Identifie le langage qui invite à l'honnêteté, réduit la peur, protège la dignité et rassure sur l'expression sûre.",
  "metric_100_name": "Ambivalence Relationnelle",
  "metric_100_description": "Détecte l'incertitude, l'engagement mixte, les messages de tirer-pousser ou le désir peu clair de continuer.",
