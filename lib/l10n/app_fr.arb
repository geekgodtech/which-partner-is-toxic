  "metric_good_65_name": "Réassurance sans exigence",
  "metric_good_65_description": "Recherche l'offre de réconfort et de sécurité sans exiger que le partenaire le mérite.",
  "metric_good_66_name": "Connexion authentique",
  "metric_good_66_description": "Détecte la présence authentique, le partage réel et l'abandon des faux-semblants dans les interactions.",
  "metric_good_67_name": "Encouragement mutuel",
  "metric_good_67_description": "Identifie les deux partenaires qui s'encouragent mutuellement et célèbrent les efforts, pas seulement les résultats.",
  "metric_good_68_name": "Questionnement respectueux",
  "metric_good_68_description": "Suit le fait de demander le point de vue du partenaire avec une curiosité sincère plutôt qu'un interrogatoire.",
  "metric_good_69_name": "Cohérence aimante",
  "metric_good_69_description": "Mesure le fait de se montrer de la même manière dans les bons moments et les moments difficiles, fiable dans l'affection.",
  "metric_good_70_name": "Réciprocité émotionnelle",
  "metric_good_70_description": "Recherche les deux partenaires partageant leurs sentiments, besoins et vulnérabilités de manière équilibrée.",
  "metric_good_71_name": "Présence joyeuse",
