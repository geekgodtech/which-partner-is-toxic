  "metric_bad_23_name": "Critique déguisée en aide",
  "metric_bad_23_description": "Détecte les critiques enveloppées dans un langage du type « j'essaie juste d'aider » ou « pour ton bien ».",
  "metric_bad_24_name": "Schémas de négligence",
  "metric_bad_24_description": "Identifie un échec constant à répondre aux besoins émotionnels, physiques ou relationnels.",
  "metric_bad_25_name": "Rumination conflictuelle",
  "metric_bad_25_description": "Suit le ressassement obsessionnel des conflits sans avancer vers une résolution ou une clôture.",
  "metric_bad_26_name": "Rejet de la sensibilité",
