  "metric_bad_10_name": "Rétention d'informations",
  "metric_bad_10_description": "Identifie l'omission délibérée de faits, de contexte ou de transparence pour maintenir le contrôle.",
  "metric_bad_11_name": "Colère disproportionnée",
  "metric_bad_11_description": "Repère les réactions de colère nettement disproportionnées par rapport à l'incident déclencheur.",
  "metric_bad_12_name": "Addiction à la réassurance",
  "metric_bad_12_description": "Signale un besoin constant de validation, des questions répétées sur l'engagement ou une quête incessante de preuves d'amour.",
  "metric_bad_13_name": "Évitement des conversations",
  "metric_bad_13_description": "Détecte le refus de s'engager dans les préoccupations, les phrases d'évitement ou la fermeture des discussions importantes.",
  "metric_bad_14_name": "Schéma de contradiction",
