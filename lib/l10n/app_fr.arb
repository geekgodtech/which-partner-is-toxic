  "metric_good_1_name": "Indices d'écoute active",
  "metric_good_1_description": "Détecte la reformulation, les questions de clarification et la compréhension démontrée du point de vue du partenaire dans le texte.",
  "metric_good_2_name": "Expression d'appréciation",
  "metric_good_2_description": "Identifie les expressions de gratitude spécifiques, la reconnaissance des efforts et l'appréciation des qualités ou actions positives du partenaire.",
  "metric_good_3_name": "Langage d'Affirmation",
  "metric_good_3_description": "Recherche les déclarations qui valident les sentiments, expériences, valeur ou droit aux besoins du partenaire.",
  "metric_good_4_name": "Ton collaboratif",
  "metric_good_4_description": "Mesure l'utilisation du « nous », d'un langage de résolution conjointe des problèmes, et la présentation des enjeux comme des défis à relever ensemble.",
  "metric_good_5_name": "Curiosité envers le partenaire",
  "metric_good_5_description": "Suit les questions sur les pensées, les sentiments, la journée, les préférences ou l'expérience intérieure du partenaire.",
  "metric_good_6_name": "Expression de la vulnérabilité",
  "metric_good_6_description": "Identifie le partage des peurs, insécurités, besoins ou vérités émotionnelles sans défense ni blâme.",
  "metric_good_7_name": "Humour comme lien",
  "metric_good_7_description": "Détecte un rire partagé et ludique qui rapproche les partenaires, sans moquerie ni dénigrement.",
  "metric_good_8_name": "Offre de réassurance",
  "metric_good_8_description": "Recherche les déclarations proactives qui apportent réconfort, sécurité ou confiance au partenaire anxieux.",
  "metric_good_9_name": "Fréquence des Compliments",
  "metric_good_9_description": "Mesure les compliments spécifiques et sincères sur l'apparence, le caractère, les capacités ou les actions positives.",
  "metric_good_10_name": "Disponibilité émotionnelle",
  "metric_good_10_description": "Évalue la réceptivité aux besoins émotionnels du partenaire, la présence en détresse et la volonté de s'engager.",
  "metric_good_11_name": "Habitude de gratitude",
  "metric_good_11_description": "Identifie les expressions régulières de remerciements pour les petites choses, les efforts, la présence ou le soutien.",
  "metric_good_12_name": "Langage de soutien",
  "metric_good_12_description": "Suit les déclarations offrant de l'aide, des encouragements, la croyance dans les capacités du partenaire ou le fait de se tenir à ses côtés.",
  "metric_good_13_name": "Désaccord doux",
  "metric_good_13_description": "Mesure la capacité à exprimer des opinions différentes tout en préservant le respect, la curiosité et la relation.",
  "metric_good_14_name": "Sincérité des excuses",
  "metric_good_14_description": "Détecte les remords sincères, la compréhension de l'impact et l'engagement à changer sans excuses.",
  "metric_good_15_name": "Acceptation du pardon",
  "metric_good_15_description": "Recherche la volonté de laisser aller les blessures passées, d'avancer et de reconstruire la confiance après une réparation.",
  "metric_good_16_name": "Initiation de temps de qualité",
  "metric_good_16_description": "Identifie les offres de passer du temps concentré ensemble, de planifier des activités ou de créer des moments de connexion.",
  "metric_good_17_name": "Indices d'affection physique",
  "metric_good_17_description": "Suit les mentions de toucher, câlins, baisers ou proximité physique comme expressions de soin et d'intimité.",
  "metric_good_18_name": "Reconnaissance de la joie partagée",
  "metric_good_18_description": "Mesure la célébration des victoires, réalisations, bonheur ou bonnes nouvelles du partenaire avec un enthousiasme sincère.",
  "metric_good_19_name": "Effort de résolution de conflit",
  "metric_good_19_description": "Identifie les tentatives de trouver des solutions, de faire des compromis ou de rétablir la paix après un désaccord.",
  "metric_good_20_name": "Démonstration de patience",
  "metric_good_20_description": "Détecte la tolérance au rythme, aux difficultés, à la courbe d'apprentissage ou aux besoins de traitement émotionnel du partenaire.",
  "metric_good_21_name": "Langage de prise de perspective",
  "metric_good_21_description": "Recherche des déclarations montrant la compréhension du point de vue, du contexte ou de la réalité émotionnelle du partenaire.",
  "metric_good_22_name": "Signaux de fiabilité",
  "metric_good_22_description": "Suit le respect des promesses, la constance et la fiabilité.",
  "metric_good_23_name": "Respect des différences",
  "metric_good_23_description": "Mesure l'acceptation des traits uniques, des préférences, des opinions et des manières d'être du partenaire.",
  "metric_good_24_name": "Ouverture aux retours",
  "metric_good_24_description": "Identifie la réceptivité aux préoccupations du partenaire, la volonté d'entendre les critiques et le désir de s'améliorer.",
  "metric_good_25_name": "Validation des émotions",
  "metric_good_25_description": "Détecte la reconnaissance que les sentiments du partenaire sont réels, compréhensibles et dignes d'attention.",
  "metric_good_26_name": "Langage d'encouragement",
  "metric_good_26_description": "Recherche des déclarations qui inspirent confiance, motivent l'action ou soutiennent les objectifs du partenaire.",
  "metric_good_27_name": "Divulgation intime",
  "metric_good_27_description": "Identifie le partage de pensées personnelles, de rêves, de peurs ou de secrets qui approfondissent la connexion émotionnelle.",
  "metric_good_28_name": "Signaux d'accordage",
  "metric_good_28_description": "Mesure la capacité à remarquer l'humeur, les besoins ou la détresse du partenaire sans qu'il soit nécessaire de les exprimer explicitement.",
  "metric_good_29_name": "Recadrage positif",
  "metric_good_29_description": "Détecte la recherche d'aspects positifs, d'opportunités de croissance ou d'angles constructifs dans les situations difficiles.",
  "metric_good_30_name": "Langage d'engagement",
  "metric_good_30_description": "Suit les expressions de dévouement, de vision à long terme et d'investissement dans l'avenir de la relation.",
  "metric_good_31_name": "Démonstration de flexibilité",
  "metric_good_31_description": "Identifie la volonté d'adapter les plans, d'ajuster les attentes ou de rencontrer le partenaire à mi-chemin.",
  "metric_good_32_name": "Langage protecteur",
  "metric_good_32_description": "Recherche les déclarations montrant que la sécurité, le bien-être et les intérêts du partenaire comptent profondément.",
  "metric_good_33_name": "Célébration des jalons",
  "metric_good_33_description": "Mesure la reconnaissance des anniversaires, des réalisations ou des moments significatifs partagés.",
  "metric_good_34_name": "Feedback constructif",
  "metric_good_34_description": "Détecte les suggestions d'amélioration qui sont bienveillantes, spécifiques et axées sur la croissance.",
  "metric_good_35_name": "Présence dans l'épreuve",
  "metric_good_35_description": "Identifie le maintien de l'engagement lorsque le partenaire traverse des difficultés, un deuil ou des défis.",
  "metric_good_36_name": "Expression d'admiration",
  "metric_good_36_description": "Suit le respect sincère pour le caractère, la force, l'intelligence ou la résilience du partenaire.",
  "metric_good_37_name": "Indicateurs de Ludisme",
  "metric_good_37_description": "Recherche les taquineries légères, les blagues internes ou les interactions amusantes qui renforcent les liens.",
  "metric_good_38_name": "Miroir Empathique",
  "metric_good_38_description": "Mesure le fait de refléter les émotions du partenaire pour montrer compréhension et validation.",
  "metric_good_39_name": "Langage d'Acceptation",
  "metric_good_39_description": "Détecte l'acceptation du partenaire tel qu'il est, y compris ses défauts, sans exiger de changement.",
  "metric_good_40_name": "Présence Soutenante",
  "metric_good_40_description": "Identifie la présence sans chercher à réparer, offrant du réconfort par l'écoute et la compagnie.",
  "metric_good_41_name": "Intérêt Sincère",
  "metric_good_41_description": "Suit les questions de suivi et la mémorisation des détails sur la vie et les préoccupations du partenaire.",
  "metric_good_42_name": "Effort Réciproque",
  "metric_good_42_description": "Mesure la contribution égale des deux partenaires au travail émotionnel, à la planification et à l'entretien de la relation.",
  "metric_good_43_name": "Langage de Pardon",
  "metric_good_43_description": "Recherche le lâcher-prise des rancunes, l'offre de secondes chances et le choix de dépasser la blessure.",
  "metric_good_44_name": "Signes de Respect Mutuel",
  "metric_good_44_description": "Détecte le traitement du partenaire comme un égal, le respect de ses opinions et la valorisation de sa contribution.",
  "metric_good_45_name": "Honnêteté Émotionnelle",
  "metric_good_45_description": "Identifie l'expression honnête des sentiments sans manipulation, exagération ou rétention stratégique.",
  "metric_good_46_name": "Écoute bienveillante",
  "metric_good_46_description": "Mesure la capacité à laisser le partenaire s'exprimer pleinement sans l'interrompre, le juger ou chercher immédiatement une solution.",
  "metric_good_47_name": "Surnoms affectueux",
  "metric_good_47_description": "Repère l'utilisation de surnoms affectueux qui transmettent chaleur et connexion intime.",
  "metric_good_48_name": "Rire partagé",
  "metric_good_48_description": "Identifie les moments d'humour et de joie partagés qui créent des liens positifs.",
  "metric_good_49_name": "Gestes attentionnés",
  "metric_good_49_description": "Recherche les petits gestes de gentillesse, le fait de se souvenir des préférences ou d'agir pour faire plaisir au partenaire.",
  "metric_good_50_name": "Confiance dans le partenaire",
  "metric_good_50_description": "Détecte la croyance dans les capacités, le potentiel et la capacité du partenaire à relever les défis.",
  "metric_good_51_name": "Interdépendance saine",
  "metric_good_51_description": "Mesure l'équilibre entre la proximité et l'indépendance, en soutenant l'autonomie de chacun.",
  "metric_good_52_name": "Désescalade des conflits",
  "metric_good_52_description": "Identifie un langage doux, des pauses ou des propositions de solution pour apaiser les discussions animées.",
  "metric_good_53_name": "Excuses sincères",
  "metric_good_53_description": "Repère la reconnaissance complète d'une erreur sans minimisation, défense ou rejet de la faute.",
  "metric_good_54_name": "Offres de soutien émotionnel",
  "metric_good_54_description": "Recherche les vérifications proactives, les demandes sur l'état du partenaire et les offres d'aide.",
  "metric_good_55_name": "Limites respectueuses",
  "metric_good_55_description": "Mesure le respect des limites énoncées par le partenaire tout en maintenant ses propres limites saines.",
  "metric_good_56_name": "Anticipation positive",
  "metric_good_56_description": "Détecte l'enthousiasme pour l'avenir ensemble, la planification et l'impatience de partager des expériences.",
  "metric_good_57_name": "Signes d'attention",
  "metric_good_57_description": "Identifie la mémorisation des dates importantes, des préférences et des détails qui montrent que le partenaire compte.",
  "metric_good_58_name": "Encouragement à grandir",
  "metric_good_58_description": "Suit le soutien au développement personnel, à l'apprentissage et à la poursuite des objectifs du partenaire.",
  "metric_good_59_name": "Langage tendre",
  "metric_good_59_description": "Recherche des choix de mots doux et attentionnés qui transmettent de la tendresse et de la chaleur émotionnelle.",
  "metric_good_60_name": "Responsabilité mutuelle",
  "metric_good_60_description": "Mesure la prise de responsabilité des deux partenaires pour leurs actions et leur impact.",
  "metric_good_61_name": "Célébration du partenaire",
  "metric_good_61_description": "Détecte l'expression publique ou privée de fierté, de joie ou d'admiration pour le partenaire.",
  "metric_good_62_name": "Affection constante",
  "metric_good_62_description": "Identifie les expressions régulières d'amour qui ne fluctuent pas en fonction de la performance ou de la conformité.",
  "metric_good_63_name": "Accord émotionnel",
  "metric_good_63_description": "Suit la perception et la réponse aux changements subtils de l'état émotionnel du partenaire.",
  "metric_good_64_name": "Prise de décision collaborative",
