  "metric_good_73_name": "Défense protectrice",
  "metric_good_73_description": "Mesure la défense du partenaire, sa protection et la priorisation de son bien-être.",
  "metric_good_74_name": "Communication consciente",
  "metric_good_74_description": "Évalue le choix réfléchi des mots, la considération de l'impact avant de parler et la communication intentionnelle.",
  "metric_good_75_name": "Investissement relationnel",
  "metric_good_75_description": "Recherche le temps, l'énergie et les ressources consacrés à nourrir la relation.",
  "metric_good_76_name": "Langage de base sécurisante",
  "metric_good_76_description": "Détecte l'offre de stabilité, de sécurité et d'une base à partir de laquelle le partenaire peut explorer.",
  "metric_good_77_name": "Admiration mutuelle",
  "metric_good_77_description": "Identifie les deux partenaires exprimant respect et appréciation pour les qualités de l'autre.",
  "metric_good_78_name": "Moments tendres",
  "metric_good_78_description": "Mesure la création ou la reconnaissance de moments intimes et silencieux de connexion et de proximité.",
  "metric_good_79_name": "Curiosité sincère",
  "metric_good_79_description": "Recherche un intérêt authentique à comprendre les pensées, sentiments et expériences du partenaire.",
  "metric_good_80_name": "Acceptation aimante",
  "metric_good_80_description": "Détecte l'acceptation de l'être entier du partenaire, y compris ses imperfections et son passé.",
  "metric_good_81_name": "Soutien mutuel à la croissance",
  "metric_good_81_description": "Identifie les deux partenaires s'encourageant mutuellement dans leur développement et célébrant les progrès.",
  "metric_good_82_name": "Indicateurs de ton chaleureux",
  "metric_good_82_description": "Suit l'utilisation d'un langage affectueux, de formulations aimables et d'un style de communication doux.",
  "metric_good_83_name": "Engagement réactif",
  "metric_good_83_description": "Mesure les réponses rapides et engagées aux messages et aux sollicitations émotionnelles du partenaire.",
  "metric_good_84_name": "Alignement des valeurs partagées",
  "metric_good_84_description": "Recherche les références à des croyances, objectifs ou philosophies de vie communs qui unissent le couple.",
  "metric_good_85_name": "Soutien inconditionnel",
  "metric_good_85_description": "Détecte le fait de soutenir le partenaire dans les difficultés sans conditionner ce soutien.",
  "metric_good_86_name": "Vulnérabilité intime",
  "metric_good_86_description": "Identifie le partage de peurs profondes, de rêves ou d'insécurités qui renforcent les liens émotionnels.",
  "metric_good_87_name": "Langage de respect mutuel",
  "metric_good_87_description": "Suit le respect des perspectives, choix et autonomie de chacun dans la communication.",
  "metric_good_88_name": "Cadrage positif",
  "metric_good_88_description": "Mesure la capacité à voir le meilleur dans les situations et chez le partenaire, en se concentrant sur les forces.",
  "metric_good_89_name": "Résolution collaborative de problèmes",
  "metric_good_89_description": "Recherche la collaboration vers des solutions qui profitent également aux deux partenaires.",
  "metric_good_90_name": "Validation émotionnelle",
  "metric_good_90_description": "Détecte la confirmation que les sentiments du partenaire sont compréhensibles et acceptables.",
  "metric_good_91_name": "Gentillesse Constante",
  "metric_good_91_description": "Identifie les petits gestes d'attention réguliers qui montrent que le partenaire est pensé et valorisé.",
  "metric_good_92_name": "Célébration Mutuelle",
  "metric_good_92_description": "Mesure la joie authentique des deux partenaires face aux succès et aux bonheurs de l'autre.",
  "metric_good_93_name": "Langage d'Attachement Sécurisé",
  "metric_good_93_description": "Évalue l'expression de la confiance, du confort avec l'intimité et de la confiance dans la relation.",
  "metric_good_94_name": "Considération Réfléchie",
  "metric_good_94_description": "Recherche les décisions prises en tenant compte des besoins et des sentiments du partenaire.",
  "metric_good_95_name": "Présence Aimante",
  "metric_good_95_description": "Détecte une présence pleine et engagée, montrant au partenaire qu'il est la priorité.",
  "metric_good_96_name": "Langage de Soin Authentique",
  "metric_good_96_description": "Mesure les expressions authentiques de préoccupation, d'attention et d'investissement dans le bien-être du partenaire.",
  "metric_good_97_name": "Engagement Relationnel",
  "metric_good_97_description": "Évalue l'expression de l'engagement envers le partenariat et la volonté de surmonter les défis.",
  "metric_good_98_name": "Expression d'Amour Authentique",
  "metric_good_98_description": "Recherche des expressions d'amour authentiques et constantes, qui semblent réelles et inconditionnelles.",
  "metric_good_99_name": "Définition d'Objectifs Mutuels",
  "metric_good_99_description": "Identifie les partenaires qui définissent ensemble leurs rêves, priorités et orientations pour leur avenir commun.",
  "metric_good_100_name": "Reconnaissance des tentatives de réparation",
  "metric_good_100_description": "Détecte le fait de remarquer et de répondre positivement aux tentatives de rapprochement du partenaire pour désamorcer un conflit et rétablir la connexion.",
  "metric_bad_1_name": "Agressivité passive",
  "metric_bad_1_description": "Détecte l'hostilité indirecte par la procrastination, l'oubli, le sarcasme ou le sabotage subtil au lieu d'une expression directe.",
  "metric_bad_2_name": "Instrumentalisation de la culpabilité",
  "metric_bad_2_description": "Identifie l'utilisation de la culpabilité, de la honte ou d'un langage d'obligation pour manipuler les décisions ou empêcher la fixation de limites.",
  "metric_bad_3_name": "Chantage affectif",
  "metric_bad_3_description": "Signale les menaces d'automutilation, d'abandon ou de retrait d'affection pour contrôler le comportement ou empêcher la discussion.",
  "metric_bad_4_name": "Plainte chronique",
